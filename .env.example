# Ten plik dokumentuje zmienne, jakich oczekuje warstwa infra (root) tego repo.
# NIGDY nie wypełniaj tego pliku prawdziwymi wartościami i nie commituj wypełnionego .env.
#
# Realny .env (z prawdziwymi tokenami) NIE MOŻE fizycznie leżeć w tym katalogu — cały katalog
# repo jest bind-mountowany do devcontainera (docker-compose.yml: `.:/workspace`), więc
# cokolwiek tu leży jest czytelne dla każdego procesu w kontenerze, w tym dla agentów AI.
# Trzymaj realny .env poza repo (np. ~/.config/ocr-ai/.env) i wczytuj go ręcznie tylko poza
# tym devcontainerem, gdy naprawdę potrzebujesz uderzyć w żywe API. Zobacz CLAUDE.md.

# OVH AI Endpoints
OVH_AI_ENDPOINTS_ACCESS_TOKEN=your-token-here
OVH_AI_ENDPOINT=https://oai.endpoints.kepler.ai.cloud.ovh.net/v1/chat/completions

# Strategia modeli - biblioteka próbuje kolejno od pierwszego
# Opcje: lite, medium, premium, google_vision
OCR_MODEL_PRIORITY=medium,premium,lite

# Modele Visual LLM w OVH (multimodal - przyjmują obrazy)
OVH_MODEL_LITE=Qwen3.5-9B
OVH_MODEL_MEDIUM=Mistral-Small-3.2-24B-Instruct-2506
OVH_MODEL_PREMIUM=Qwen3.6-27B

# Google Vision Fallback (opcjonalny - domyslnie WYLACZONY)
GOOGLE_VISION_ENABLED=false
VISION_LOGIN=/path/to/service-account.json
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Klucz do MCP serwera Perplexity (uzywany przez narzedzia AI, nie przez biblioteke OCR)
PERPLEXITY_KEY=your-perplexity-key-here

# Aplikacja
APP_DEBUG=false
APP_LOCALE=pl
FALLBACK_LOCALE=en

# Logowanie
LOG_FILE=storage/logs/ocr.log

# Bearer token do zdalnego MCP task-boardu (devbrain) - jesli uzywany
MCP_BEARER_TOKEN=your-mcp-bearer-token-here
