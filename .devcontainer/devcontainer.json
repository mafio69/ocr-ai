{
  "name": "PHP",
  "image": "mafio69/php-env:8.4-fpm-alpine",
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "forwardPorts": [9999],
  "overrideCommand": true,
  "postCreateCommand": "composer install || true",
  "customizations": {
    "jetbrains": {
      "backend": "PhpStorm"
    }
  }
}