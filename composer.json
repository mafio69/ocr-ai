{
  "name": "mafio69/ovh-ocr",
  "description": "PHP library for extracting text from images - Visual LLM (OVH AI Endpoints) with optional fallback to Google Vision. Support PL/EN.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "mafio69",
      "email": "your-email@example.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "guzzlehttp/guzzle": "^7.5",
    "psr/log": "^3.0",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-fileinfo": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "vlucas/phpdotenv": "^5.5",
    "mpdf/mpdf": "^8.2",
    "smalot/pdfparser": "^2.9"
  },
  "suggest": {
    "vlucas/phpdotenv": "To load configurations from an .env file in applications",
    "mpdf/mpdf": "To enable OcrClient::extractTextAsSearchablePdf() / SearchablePdfWriter (searchable PDF export) - not required for plain text extraction"
  },
  "autoload": {
    "psr-4": {
      "OvhOcr\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OvhOcr\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": [
      "@check:asserts",
      "@test:phpunit"
    ],
    "check:asserts": "bash scripts/check-trivial-asserts.sh tests",
    "test:phpunit": "phpunit --colors=always",
    "test-coverage": "phpunit --coverage-text"
  },
  "scripts-descriptions": {
    "test": "All tests: trivial-assertion gate + PHPUnit",
    "check:asserts": "Scans tests/ for trivial assertions (blocks if found)",
    "test:phpunit": "PHPUnit only"
  },
  "keywords": [
    "ocr",
    "ovh",
    "ai-endpoints",
    "visual-llm",
    "vision",
    "text-extraction",
    "image-to-text",
    "multimodal",
    "php"
  ],
  "homepage": "https://github.com/mafio69/ovh-ocr",
  "support": {
    "issues": "https://github.com/mafio69/ovh-ocr/issues",
    "source": "https://github.com/mafio69/ovh-ocr"
  },
  "minimum-stability": "stable"
}
